<Window x:Class="SEP.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SEP - SMT Engineering Platform"
        Width="1600"
        Height="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" FontSize="16">
            <MenuItem Header="_Файл">
                <MenuItem Header="Открыть базу данных"/>
                <Separator/>
                <MenuItem Header="Выход"
                          Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Компоненты"/>
            <MenuItem Header="_Трафареты"/>
            <MenuItem Header="_VisualCAM"/>
            <MenuItem Header="_Mirtec"/>
            <MenuItem Header="_Инструменты"/>
            <MenuItem Header="_Справка"/>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="📂 Открыть" FontSize="14"/>
                <Separator/>
                <Button Content="📦 Компоненты" FontSize="14"/>
                <Button Content="🖨 Трафарет" FontSize="14"/>
                <Button Content="📄 PDF" FontSize="14"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Строка состояния -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Готов"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Основная область -->
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <GroupBox Header="Библиотека компонентов"
                      Grid.Column="0"
                      Margin="5"
                      FontSize="16">

                <TreeView x:Name="PackagesTree"
                          FontSize="15"/>

            </GroupBox>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <!-- Правая часть -->
            <Grid Grid.Column="2"
                  Margin="5">

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        Background="#F8F8F8">

                    <TextBlock Text="Просмотр корпуса"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="15,0"/>

                </Border>

                <Border Grid.Row="1"
                        Margin="0,5,0,0"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        Background="White">

                    <TextBlock Text="Выберите корпус слева"
                               FontSize="28"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                </Border>

            </Grid>

        </Grid>

    </DockPanel>

</Window>