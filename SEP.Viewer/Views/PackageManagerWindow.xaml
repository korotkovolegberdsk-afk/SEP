<Window x:Class="SEP.Viewer.Views.PackageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master Library"
        Width="1300"
        Height="750"
        WindowStartupLocation="CenterOwner">

    <DockPanel>

        <ToolBar DockPanel.Dock="Top">
            <Button x:Name="NewButton" Content="➕ Новый" Width="90"/>
            <Button x:Name="EditButton" Content="✏ Редактировать" Width="110"/>
            <Button x:Name="DeleteButton" Content="🗑 Удалить" Width="90"/>
            <Separator/>
            <TextBox Width="250"/>
        </ToolBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView x:Name="PackageTree" Grid.Column="0"/>

            <GridSplitter Grid.Column="1" Width="5"/>

            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Name:"/>
                <TextBlock x:Name="NameText" Grid.Column="1"/>

                <TextBlock Grid.Row="1" Text="Type:"/>
                <TextBlock x:Name="TypeText" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Grid.Row="2" Text="Length:"/>
                <TextBlock x:Name="LengthText" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Grid.Row="3" Text="Width:"/>
                <TextBlock x:Name="WidthText" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Grid.Row="4" Text="Height:"/>
                <TextBlock x:Name="HeightText" Grid.Row="4" Grid.Column="1"/>

                <TextBlock Grid.Row="5" Text="Description:"/>
                <TextBlock x:Name="DescriptionText" Grid.Row="5" Grid.Column="1"/>

                <TextBlock Grid.Row="6" Text="Pitch:"/>
                <TextBlock x:Name="PitchText" Grid.Row="6" Grid.Column="1"/>

                <TextBlock Grid.Row="7" Text="Pins:"/>
                <TextBlock x:Name="PinsText" Grid.Row="7" Grid.Column="1"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
