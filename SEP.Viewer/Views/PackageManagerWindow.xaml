<Window x:Class="SEP.Viewer.Views.PackageManagerWindow"
        Title="Package Manager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TreeView x:Name="PackageTree"
                  Grid.Column="0"/>

        <StackPanel Grid.Column="1" Margin="20,0,0,0">
            <TextBlock Text="Название:"/>
            <TextBlock x:Name="NameText"/>
            <TextBlock Text="Тип:"/>
            <TextBlock x:Name="TypeText"/>
            <TextBlock Text="Длина:"/>
            <TextBlock x:Name="LengthText"/>
            <TextBlock Text="Ширина:"/>
            <TextBlock x:Name="WidthText"/>
            <TextBlock Text="Высота:"/>
            <TextBlock x:Name="HeightText"/>
            <TextBlock Text="Pitch:"/>
            <TextBlock x:Name="PitchText"/>
            <TextBlock Text="Выводов:"/>
            <TextBlock x:Name="PinsText"/>
            <TextBlock Text="Описание:"/>
            <TextBlock x:Name="DescriptionText"/>
        </StackPanel>
    </Grid>
</Window>
