<Window x:Class="SEP.Viewer.Views.PackageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master Library"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TreeView x:Name="PackageTree"
                  Grid.Column="0"/>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"/>

        <Grid Grid.Column="2"
              Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Package"/>
            <TextBlock Grid.Column="1" x:Name="NameText"/>

            <TextBlock Grid.Row="1" Text="Type"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TypeText"/>

            <TextBlock Grid.Row="2" Text="Length"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LengthText"/>

            <TextBlock Grid.Row="3" Text="Width"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="WidthText"/>

            <TextBlock Grid.Row="4" Text="Height"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="HeightText"/>

            <TextBlock Grid.Row="5" Text="Pins"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PinsText"/>

        </Grid>

    </Grid>

</Window>
