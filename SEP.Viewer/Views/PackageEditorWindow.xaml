<Window x:Class="SEP.Viewer.Views.PackageEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор корпуса"
        Width="600"
        Height="750"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <TextBlock Text="Имя корпуса"
                       Grid.Row="0"/>
            <TextBox x:Name="NameBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Тип"
                       Grid.Row="1"/>
            <TextBox x:Name="TypeBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Длина (мм)"
                       Grid.Row="2"/>
            <TextBox x:Name="LengthBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Ширина (мм)"
                       Grid.Row="3"/>
            <TextBox x:Name="WidthBox"
                     Grid.Row="3"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Высота (мм)"
                       Grid.Row="4"/>
            <TextBox x:Name="HeightBox"
                     Grid.Row="4"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Pitch"
                       Grid.Row="5"/>
            <TextBox x:Name="PitchBox"
                     Grid.Row="5"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Количество выводов"
                       Grid.Row="6"/>
            <TextBox x:Name="PinsBox"
                     Grid.Row="6"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Толщина трафарета"
                       Grid.Row="7"/>
            <TextBox x:Name="StencilThicknessBox"
                     Grid.Row="7"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Уменьшение апертуры (%)"
                       Grid.Row="8"/>
            <TextBox x:Name="ApertureReductionBox"
                     Grid.Row="8"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Алгоритм AOI"
                       Grid.Row="9"/>
            <TextBox x:Name="AOIAlgorithmBox"
                     Grid.Row="9"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Примечания"
                       Grid.Row="10"/>
            <TextBox x:Name="NotesBox"
                     Grid.Row="10"
                     Grid.Column="1"
                     Margin="5"/>


            <TextBlock Text="Описание"
                       Grid.Row="11"/>
            <TextBox x:Name="DescriptionBox"
                     Grid.Row="11"
                     Grid.Column="1"
                     Margin="5"
                     Height="80"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>


            <Button Grid.Row="12"
                    Grid.Column="1"
                    Content="Сохранить"
                    Width="120"
                    Height="30"
                    HorizontalAlignment="Right"
                    Margin="5"
                    Click="SaveButton_Click"/>

        </Grid>

    </ScrollViewer>

</Window>