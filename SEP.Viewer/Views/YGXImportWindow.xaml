<Window x:Class="SEP.Viewer.Views.YGXImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YGX Import"
        Width="1300"
        Height="700"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="10">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>


		<TextBlock x:Name="InfoText"
                   FontSize="18"
                   Margin="5"/>


		<DataGrid x:Name="ComponentsGrid"
                  Grid.Row="1"
                  Margin="5"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">


			<DataGrid.Columns>

				<DataGridTextColumn Header="Reference"
                                    Binding="{Binding Reference}"
                                    Width="120"/>

				<DataGridTextColumn Header="Part Number"
                                    Binding="{Binding PartNumber}"
                                    Width="180"/>

				<DataGridTextColumn Header="Database"
                                    Binding="{Binding DatabaseNo}"
                                    Width="80"/>

				<DataGridTextColumn Header="Shape"
                                    Binding="{Binding ShapeType}"
                                    Width="70"/>

				<DataGridTextColumn Header="Package Type"
                                    Binding="{Binding PackageType}"
                                    Width="100"/>

				<DataGridTextColumn Header="X"
                                    Binding="{Binding X}"
                                    Width="90"/>

				<DataGridTextColumn Header="Y"
                                    Binding="{Binding Y}"
                                    Width="90"/>

				<DataGridTextColumn Header="Body X"
                                    Binding="{Binding BodyX}"
                                    Width="80"/>

				<DataGridTextColumn Header="Body Y"
                                    Binding="{Binding BodyY}"
                                    Width="80"/>

				<DataGridTextColumn Header="Body Z"
                                    Binding="{Binding BodyZ}"
                                    Width="80"/>

			</DataGrid.Columns>


		</DataGrid>


		<Button Grid.Row="2"
                Width="120"
                Height="35"
                HorizontalAlignment="Right"
                Margin="5"
                Content="Закрыть"
                Click="Close_Click"/>

	</Grid>

</Window>